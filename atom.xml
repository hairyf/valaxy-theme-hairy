        <content type="html"><![CDATA[<h2>Hello, Valaxy!</h2>
<pre><code class="language-ts">import type { ThemeConfig } from 'valaxy-theme-hairy'
import { defineConfig } from 'valaxy'

export default defineConfig&lt;ThemeConfig&gt;({
  // your theme name
  // valaxy-theme-yun name is 'yun'
  theme: 'starter',

  themeConfig: {
    banner: {
      enable: true,
      title: '云游君的小站',
    },
  },
})
</code></pre>
